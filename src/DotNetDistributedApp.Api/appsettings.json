{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:o} {Level:u3}] {Message:lj}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "applyThemeToRedirectedOutput": true
        }
      },
      {
        "Name": "OpenTelemetry"
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "HttpClient": {
    "CoordinateConverterClient": {
      "Resilience": {
        "AttemptTimeout": { "Timeout": "00:00:05" },
        "TotalRequestTimeout": { "Timeout": "00:00:30" },
        "Retry": {
          "MaxRetryAttempts": 3,
          "Delay": "00:00:00.500",
          "BackoffType": "Exponential",
          "UseJitter": true
        },
        "CircuitBreaker": {
          "FailureRatio": 0.5,
          "MinimumThroughput": 10,
          "SamplingDuration": "00:00:30",
          "BreakDuration": "00:00:15"
        }
      }
    },
    "GeoIpClient": {
      "Resilience": {
        "AttemptTimeout": { "Timeout": "00:00:05" },
        "TotalRequestTimeout": { "Timeout": "00:00:30" },
        "Retry": {
          "MaxRetryAttempts": 3,
          "Delay": "00:00:00.500",
          "BackoffType": "Exponential",
          "UseJitter": true
        },
        "CircuitBreaker": {
          "FailureRatio": 0.5,
          "MinimumThroughput": 10,
          "SamplingDuration": "00:00:30",
          "BreakDuration": "00:00:15"
        }
      }
    }
  }
}
